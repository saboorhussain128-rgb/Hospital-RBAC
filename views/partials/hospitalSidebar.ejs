<div style="
width:230px;
height:100vh;
background:#2c3e50;
position:fixed;
left:0;
top:0;
padding-top:30px;">

    <h2 style="color:white;text-align:center;">
        Hospital Admin
    </h2>

    <% if (session.user.permissions.includes("create_doctor")) { %>

        <a href="/hospital/create-doctor"
           style="display:block;padding:15px;color:white;text-decoration:none;">
            Create Doctor
        </a>

    <% } %>

    <% if (session.user.permissions.includes("view_doctor")) { %>

        <a href="/hospital/view-doctor"
           style="display:block;padding:15px;color:white;text-decoration:none;">
            View Doctor
        </a>

    <% } %>

    <% if (session.user.permissions.includes("delete_doctor")) { %>

        <a href="/hospital/delete-doctor"
           style="display:block;padding:15px;color:white;text-decoration:none;">
            Delete Doctor
        </a>

    <% } %>

    <a href="/logout"
       style="display:block;padding:15px;color:white;text-decoration:none;">
        Logout
    </a>

</div>