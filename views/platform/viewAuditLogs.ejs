<!DOCTYPE html>
<html>

<%- include("../partials/header") %>

<body style="margin:0;background:#f4f6f9;">

<%- include("../partials/sidebar") %>

<div class="page">

    <div class="card">

        <h1 style="margin-bottom:10px;">

            📜 Audit Logs

        </h1>

        <p style="color:#777;">

            Complete activity history of the Hospital RBAC System.

        </p>

    </div>

    <br>

    <div class="card">

        <table>

            <thead>

                <tr>

                    <th>#</th>

                    <th>Date & Time</th>

                    <th>Module</th>

                    <th>Action</th>

                    <th>User</th>

                    <th>IP Address</th>

                    <th>Description</th>

                </tr>

            </thead>

            <tbody>

            <% if(logs.length===0){ %>

                <tr>

                    <td colspan="7" style="text-align:center;">

                        No Audit Logs Available

                    </td>

                </tr>

            <% } %>

            <% logs.forEach((log,index)=>{ %>

                <tr>

                    <td>

                        <%= index+1 %>

                    </td>

                    <td>

                        <%= new Date(log.createdAt).toLocaleString() %>

                    </td>

                    <td>

                        <%= log.module %>

                    </td>

                    <td>

                        <%= log.action %>

                    </td>

                    <td>

                        <%= log.userName || "Platform Admin" %>

                    </td>

                    <td>

                        <%= log.ipAddress %>

                    </td>

                    <td>

                        <%= log.description %>

                    </td>

                </tr>

            <% }) %>

            </tbody>

        </table>

    </div>

</div>

</body>

</html>