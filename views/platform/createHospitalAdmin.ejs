<!DOCTYPE html>
<html>

<%- include("../partials/header") %>

<body style="margin:0;background:#f4f6f9;">

<%- include("../partials/sidebar") %>

<div class="page">

    <!-- ================= PAGE HEADER ================= -->

    <div class="page-header">

        <div class="page-title">

            <h1>Create Hospital Admin</h1>

            <p>
                Assign a Hospital Administrator and configure RBAC permissions.
            </p>

        </div>

        <div>

            <a href="/platform/dashboard"
               class="btn btn-gray">

                ← Dashboard

            </a>

            <a href="/platform/view-hospital-admin"
               class="btn btn-green"
               style="margin-left:10px;">

                View Hospital Admins

            </a>

        </div>

    </div>

    <!-- ================= FORM ================= -->

    <div class="card" style="max-width:850px;margin:auto;">

        <form method="POST"
              action="/platform/create-hospital-admin">

            <!-- Hospital -->

            <div style="margin-bottom:20px;">

                <label><b>Select Hospital</b></label>

                <select
                    name="hospital"
                    required
                    style="
                        width:100%;
                        padding:12px;
                        margin-top:8px;
                        border-radius:8px;
                        border:1px solid #ccc;
                    ">

                    <option value="">Choose Hospital</option>

                    <% hospitals.forEach(hospital=>{ %>

                        <option value="<%= hospital._id %>">

                            <%= hospital.name %>

                        </option>

                    <% }) %>

                </select>

            </div>

            <!-- Name -->

            <div style="margin-bottom:20px;">

                <label><b>Administrator Name</b></label>

                <input
                    type="text"
                    name="name"
                    required
                    placeholder="Enter Admin Name"
                    style="
                        width:100%;
                        padding:12px;
                        margin-top:8px;
                        border-radius:8px;
                        border:1px solid #ccc;
                    ">

            </div>

            <!-- Email -->

            <div style="margin-bottom:20px;">

                <label><b>Email Address</b></label>

                <input
                    type="email"
                    name="email"
                    required
                    placeholder="Enter Email"
                    style="
                        width:100%;
                        padding:12px;
                        margin-top:8px;
                        border-radius:8px;
                        border:1px solid #ccc;
                    ">

            </div>

            <!-- Password -->

            <div style="margin-bottom:30px;">

                <label><b>Password</b></label>

                <input
                    type="password"
                    name="password"
                    required
                    placeholder="Enter Password"
                    style="
                        width:100%;
                        padding:12px;
                        margin-top:8px;
                        border-radius:8px;
                        border:1px solid #ccc;
                    ">

            </div>

            <!-- Permissions -->

            <h3 style="margin-bottom:20px;color:#2c3e50;">

                Assign Permissions

            </h3>

            <div style="
                display:grid;
                grid-template-columns:repeat(3,1fr);
                gap:20px;
                margin-bottom:35px;
            ">

                <label class="card" style="cursor:pointer;text-align:center;">

                    <input
                        type="checkbox"
                        name="permissions"
                        value="create_doctor">

                    <br><br>

                    🩺

                    <h4>Create Doctor</h4>

                </label>

                <label class="card" style="cursor:pointer;text-align:center;">

                    <input
                        type="checkbox"
                        name="permissions"
                        value="view_doctor">

                    <br><br>

                    📋

                    <h4>View Doctor</h4>

                </label>

                <label class="card" style="cursor:pointer;text-align:center;">

                    <input
                        type="checkbox"
                        name="permissions"
                        value="delete_doctor">

                    <br><br>

                    ❌

                    <h4>Delete Doctor</h4>

                </label>

            </div>

            <button
                class="btn btn-blue"
                style="font-size:16px;">

                Create Hospital Admin

            </button>

        </form>

    </div>

</div>

</body>

</html>