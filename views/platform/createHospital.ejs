<!DOCTYPE html>
<html>

<%- include("../partials/header") %>

<body style="margin:0;background:#f4f6f9;">

<%- include("../partials/sidebar") %>

<div class="page">

    <!-- ================= PAGE HEADER ================= -->

    <div class="page-header">

        <div class="page-title">

            <h1>Create Hospital</h1>

            <p>
                Register a new hospital in the Hospital RBAC System.
            </p>

        </div>

        <div>

            <a href="/platform/dashboard" class="btn btn-gray">
                ← Dashboard
            </a>

            <a href="/platform/view-hospital"
               class="btn btn-green"
               style="margin-left:10px;">
                View Hospitals
            </a>

        </div>

    </div>

    <!-- ================= VALIDATION ERRORS ================= -->

    <% if (errors && errors.length > 0) { %>

        <div style="
            background:#fdecea;
            color:#b71c1c;
            border:1px solid #f5c6cb;
            padding:15px;
            border-radius:8px;
            margin-bottom:25px;
        ">

            <strong>Please fix the following errors:</strong>

            <ul style="margin-top:10px;">

                <% errors.forEach(error => { %>

                    <li><%= error.msg %></li>

                <% }) %>

            </ul>

        </div>

    <% } %>

    <!-- ================= FORM ================= -->

    <div class="card" style="max-width:700px;margin:auto;">

        <form action="/platform/create-hospital" method="POST">

            <!-- Hospital Name -->

            <div style="margin-bottom:20px;">

                <label style="font-weight:bold;">
                    Hospital Name
                </label>

                <input
                    type="text"
                    name="name"
                    required
                    placeholder="Enter Hospital Name"
                    value="<%= body?.name || '' %>"
                    style="
                        width:100%;
                        padding:12px;
                        margin-top:8px;
                        border:1px solid #ccc;
                        border-radius:8px;
                        font-size:15px;
                    "
                >

            </div>

            <!-- Hospital Address -->

            <div style="margin-bottom:20px;">

                <label style="font-weight:bold;">
                    Hospital Address
                </label>

                <textarea
                    name="address"
                    required
                    rows="4"
                    placeholder="Enter Hospital Address"
                    style="
                        width:100%;
                        padding:12px;
                        margin-top:8px;
                        border:1px solid #ccc;
                        border-radius:8px;
                        resize:none;
                        font-size:15px;
                    "
                ><%= body?.address || "" %></textarea>

            </div>

            <!-- Status -->

            <div style="margin-bottom:25px;">

                <label style="font-weight:bold;">
                    Status
                </label>

                <select
                    name="status"
                    style="
                        width:100%;
                        padding:12px;
                        margin-top:8px;
                        border:1px solid #ccc;
                        border-radius:8px;
                        font-size:15px;
                    "
                >

                    <option
                        value="active"
                        <%= body?.status === "active" ? "selected" : "" %>>
                        Active
                    </option>

                    <option
                        value="inactive"
                        <%= body?.status === "inactive" ? "selected" : "" %>>
                        Inactive
                    </option>

                </select>

            </div>

            <button
                type="submit"
                class="btn btn-blue">

                Create Hospital

            </button>

        </form>

    </div>

</div>

</body>
</html>