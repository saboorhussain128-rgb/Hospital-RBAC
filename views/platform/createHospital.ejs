<!DOCTYPE html>
<html>

<%- include("../partials/header") %>

<body style="margin:0;background:#f4f6f9;">

<%- include("../partials/sidebar") %>

<div class="page">

    <!-- ================= PAGE HEADER ================= -->

    <div class="page-header">

        <div class="page-title">

            <h1>Create Hospital</h1>

            <p>
                Register a new hospital in the Hospital RBAC System.
            </p>

        </div>

        <div>

            <a href="/platform/dashboard" class="btn btn-gray">
                ← Dashboard
            </a>

            <a href="/platform/view-hospital"
               class="btn btn-green"
               style="margin-left:10px;">
                View Hospitals
            </a>

        </div>

    </div>

    <!-- ================= VALIDATION ERRORS ================= -->

    <% if (typeof errors !== "undefined" && errors.length > 0) { %>

        <div class="error-box">

            <ul>

                <% errors.forEach(error => { %>

                    <li><%= error.msg %></li>

                <% }) %>

            </ul>

        </div>

    <% } %>

    <!-- ================= FORM CARD ================= -->

    <div class="card" style="max-width:700px;margin:auto;">

        <form action="/platform/create-hospital" method="POST">

            <div style="margin-bottom:20px;">

                <label style="font-weight:bold;">
                    Hospital Name
                </label>

                <input
                    type="text"
                    name="name"
                    value="<%= typeof req !== 'undefined' ? req.body?.name : '' %>"
                    required
                    placeholder="Enter Hospital Name"
                    style="
                        width:100%;
                        padding:12px;
                        margin-top:8px;
                        border:1px solid #ccc;
                        border-radius:8px;
                        font-size:15px;
                    "
                >

            </div>

            <div style="margin-bottom:20px;">

                <label style="font-weight:bold;">
                    Hospital Address
                </label>

                <textarea
                    name="address"
                    required
                    rows="4"
                    placeholder="Enter Hospital Address"
                    style="
                        width:100%;
                        padding:12px;
                        margin-top:8px;
                        border:1px solid #ccc;
                        border-radius:8px;
                        resize:none;
                        font-size:15px;
                    "
                ><%= typeof req !== 'undefined' ? req.body?.address : '' %></textarea>

            </div>

            <div style="margin-bottom:25px;">

                <label style="font-weight:bold;">
                    Status
                </label>

                <select
                    name="status"
                    style="
                        width:100%;
                        padding:12px;
                        margin-top:8px;
                        border:1px solid #ccc;
                        border-radius:8px;
                        font-size:15px;
                    "
                >

                    <option value="active">Active</option>

                    <option value="inactive">Inactive</option>

                </select>

            </div>

            <button
                type="submit"
                class="btn btn-blue">

                Create Hospital

            </button>

        </form>

    </div>

</div>

</body>
</html>