<!DOCTYPE html>
<html>

<%- include("../partials/header") %>

<body style="margin:0; font-family:Arial; background:#f4f6f9;">

<%- include("../partials/sidebar") %>

<div style="margin-left:240px; padding:30px;">

    <!-- TOP BAR -->
    <div style="display:flex; justify-content:space-between; margin-bottom:20px;">

        <a href="/platform/dashboard" style="
            background:#34495e;
            color:white;
            padding:8px 14px;
            border-radius:6px;
            text-decoration:none;">
            ← Back to Dashboard
        </a>

        <a href="/platform/view-hospital" style="
            background:#27ae60;
            color:white;
            padding:8px 14px;
            border-radius:6px;
            text-decoration:none;">
            View Hospitals
        </a>

    </div>

    <div style="background:white; padding:25px; border-radius:10px;">

        <h2>Create Hospital</h2>

        <form action="/platform/create-hospital" method="POST">

            <label>Name</label><br>
            <input type="text" name="name" required style="width:100%;padding:10px;margin:8px 0;"><br>

            <label>Address</label><br>
            <input type="text" name="address" required style="width:100%;padding:10px;margin:8px 0;"><br>

            <label>Status</label><br>
            <select name="status" style="width:100%;padding:10px;margin:8px 0;">
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
            </select><br><br>

            <button style="
                background:#3498db;
                color:white;
                padding:10px 20px;
                border:none;
                border-radius:6px;
                cursor:pointer;">
                Create Hospital
            </button>

        </form>

    </div>

</div>

</body>
</html>