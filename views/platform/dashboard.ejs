<!DOCTYPE html>
<html>

<%- include("../partials/header") %>

<body style="margin:0;background:#f4f6f9;">

<%- include("../partials/sidebar") %>

<div class="page">

    <!-- ================= HEADER ================= -->

    <div class="card" style="text-align:center;margin-bottom:35px;">

        <h1 style="
            font-size:38px;
            color:#2c3e50;
            margin-bottom:8px;
        ">
            Platform Admin
        </h1>

        <p style="
            font-size:17px;
            color:#7f8c8d;
        ">
            Welcome, Admin 
        </p>

    </div>

    <!-- ================= STATISTICS ================= -->

    <div style="
        display:grid;
        grid-template-columns:repeat(2,1fr);
        gap:25px;
        margin-bottom:35px;
    ">

        <!-- Hospitals -->

        <div class="card"
             style="
                text-align:center;
                border-top:5px solid #3498db;
             ">

            <div style="font-size:55px;">
                🏥
            </div>

            <h3 style="margin-top:15px;">
                Hospitals
            </h3>

            <h1 style="
                color:#3498db;
                font-size:48px;
                margin-top:10px;
            ">
                <%= hospitalCount || 0 %>
            </h1>

        </div>

        <!-- Admins -->

        <div class="card"
             style="
                text-align:center;
                border-top:5px solid #27ae60;
             ">

            <div style="font-size:55px;">
                👤
            </div>

            <h3 style="margin-top:15px;">
                Hospital Admins
            </h3>

            <h1 style="
                color:#27ae60;
                font-size:48px;
                margin-top:10px;
            ">
                <%= adminCount || 0 %>
            </h1>

        </div>

    </div>

    <!-- ================= QUICK ACTIONS ================= -->

    <div class="card">

        <h2 style="
            text-align:center;
            margin-bottom:30px;
            color:#2c3e50;
        ">
            Quick Actions
        </h2>

        <div style="
            display:grid;
            grid-template-columns:repeat(2,1fr);
            gap:25px;
        ">

            <!-- Create Hospital -->

            <a href="/platform/create-hospital"
               style="text-decoration:none;color:inherit;">

                <div style="
                    border:1px solid #e6e6e6;
                    border-radius:12px;
                    padding:35px;
                    text-align:center;
                    transition:.3s;
                    cursor:pointer;
                "
                onmouseover="this.style.boxShadow='0 8px 25px rgba(0,0,0,.15)';this.style.transform='translateY(-5px)'"
                onmouseout="this.style.boxShadow='none';this.style.transform='translateY(0)'">

                    <div style="font-size:55px;">🏥</div>

                    <h3 style="margin:18px 0;">
                        Create Hospital
                    </h3>

                    <p style="color:#777;">
                        Register a new hospital.
                    </p>

                </div>

            </a>

            <!-- View Hospitals -->

            <a href="/platform/view-hospital"
               style="text-decoration:none;color:inherit;">

                <div style="
                    border:1px solid #e6e6e6;
                    border-radius:12px;
                    padding:35px;
                    text-align:center;
                    transition:.3s;
                    cursor:pointer;
                "
                onmouseover="this.style.boxShadow='0 8px 25px rgba(0,0,0,.15)';this.style.transform='translateY(-5px)'"
                onmouseout="this.style.boxShadow='none';this.style.transform='translateY(0)'">

                    <div style="font-size:55px;">📋</div>

                    <h3 style="margin:18px 0;">
                        View Hospitals
                    </h3>

                    <p style="color:#777;">
                        View, edit and delete hospitals.
                    </p>

                </div>

            </a>

            <!-- Create Admin -->

            <a href="/platform/create-hospital-admin"
               style="text-decoration:none;color:inherit;">

                <div style="
                    border:1px solid #e6e6e6;
                    border-radius:12px;
                    padding:35px;
                    text-align:center;
                    transition:.3s;
                    cursor:pointer;
                "
                onmouseover="this.style.boxShadow='0 8px 25px rgba(0,0,0,.15)';this.style.transform='translateY(-5px)'"
                onmouseout="this.style.boxShadow='none';this.style.transform='translateY(0)'">

                    <div style="font-size:55px;">👤</div>

                    <h3 style="margin:18px 0;">
                        Create Hospital Admin
                    </h3>

                    <p style="color:#777;">
                        Assign administrators with permissions.
                    </p>

                </div>

            </a>

            <!-- View Admin -->

            <a href="/platform/view-hospital-admin"
               style="text-decoration:none;color:inherit;">

                <div style="
                    border:1px solid #e6e6e6;
                    border-radius:12px;
                    padding:35px;
                    text-align:center;
                    transition:.3s;
                    cursor:pointer;
                "
                onmouseover="this.style.boxShadow='0 8px 25px rgba(0,0,0,.15)';this.style.transform='translateY(-5px)'"
                onmouseout="this.style.boxShadow='none';this.style.transform='translateY(0)'">

                    <div style="font-size:55px;">🔐</div>

                    <h3 style="margin:18px 0;">
                        View Hospital Admins
                    </h3>

                    <p style="color:#777;">
                        Manage hospital administrators.
                    </p>

                </div>

            </a>

        </div>

    </div>

</div>

</body>
</html>