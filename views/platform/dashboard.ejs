<!DOCTYPE html>
<html lang="en">

<%- include("../partials/header") %>

<body style="margin:0;background:#f4f6f9;">

<%- include("../partials/sidebar") %>

<div class="page">

    <!-- ==========================================
         PAGE HEADER
    =========================================== -->

    <div class="card" style="text-align:center;margin-bottom:35px;">

        <h1 style="
            font-size:38px;
            color:#2c3e50;
            margin-bottom:8px;
        ">
            Platform Admin Dashboard
        </h1>

        <p style="
            color:#7f8c8d;
            font-size:17px;
        ">
            Welcome, Platform Administrator
        </p>

    </div>

    <!-- ==========================================
         DASHBOARD STATISTICS
    =========================================== -->

    <div style="
        display:grid;
        grid-template-columns:repeat(3,1fr);
        gap:25px;
        margin-bottom:35px;
    ">

        <!-- Hospitals -->

        <div class="card dashboard-card blue">

            <div class="icon">
                🏥
            </div>

            <h3>Total Hospitals</h3>

            <h1>
                <%= hospitalCount || 0 %>
            </h1>

        </div>

        <!-- Hospital Admins -->

        <div class="card dashboard-card green">

            <div class="icon">
                👨‍⚕️
            </div>

            <h3>Hospital Admins</h3>

            <h1>
                <%= adminCount || 0 %>
            </h1>

        </div>

        <!-- Audit Logs -->

        <div class="card dashboard-card orange">

            <div class="icon">
                📜
            </div>

            <h3>Audit Logs</h3>

            <h1>
                <%= auditCount || 0 %>
            </h1>

        </div>

    </div>

    <!-- ==========================================
         QUICK ACTIONS
    =========================================== -->

    <div class="card">

        <h2 style="
            text-align:center;
            color:#2c3e50;
            margin-bottom:30px;
        ">
            Quick Actions
        </h2>

        <div class="actions-grid">

            <!-- Create Hospital -->

            <a href="/platform/create-hospital" class="action-link">

                <div class="action-card">

                    <div class="action-icon">
                        🏥
                    </div>

                    <h3>Create Hospital</h3>

                    <p>
                        Register a new hospital.
                    </p>

                </div>

            </a>

            <!-- View Hospitals -->

            <a href="/platform/view-hospital" class="action-link">

                <div class="action-card">

                    <div class="action-icon">
                        📋
                    </div>

                    <h3>View Hospitals</h3>

                    <p>
                        View, edit and delete hospitals.
                    </p>

                </div>

            </a>

            <!-- Create Hospital Admin -->

            <a href="/platform/create-hospital-admin" class="action-link">

                <div class="action-card">

                    <div class="action-icon">
                        👤
                    </div>

                    <h3>Create Hospital Admin</h3>

                    <p>
                        Create administrator accounts.
                    </p>

                </div>

            </a>

            <!-- View Hospital Admin -->

            <a href="/platform/view-hospital-admin" class="action-link">

                <div class="action-card">

                    <div class="action-icon">
                        🔐
                    </div>

                    <h3>View Hospital Admins</h3>

                    <p>
                        Manage administrator accounts.
                    </p>

                </div>

            </a>

            <!-- Audit Logs -->

            <a href="/platform/audit-logs" class="action-link">

                <div class="action-card">

                    <div class="action-icon">
                        📜
                    </div>

                    <h3>Audit Logs</h3>

                    <p>
                        View all system activities.
                    </p>

                </div>

            </a>

        </div>

    </div>

</div>

<style>

.actions-grid{

    display:grid;

    grid-template-columns:repeat(3,1fr);

    gap:25px;

}

.action-link{

    text-decoration:none;

    color:inherit;

}

.action-card{

    border:1px solid #e5e5e5;

    border-radius:12px;

    padding:35px;

    text-align:center;

    transition:.30s;

    background:white;

    cursor:pointer;

}

.action-card:hover{

    transform:translateY(-6px);

    box-shadow:0 10px 25px rgba(0,0,0,.15);

}

.action-icon{

    font-size:55px;

}

.action-card h3{

    margin-top:20px;

    color:#2c3e50;

}

.action-card p{

    color:#777;

}

.dashboard-card{

    text-align:center;

    border-top:5px solid;

}

.dashboard-card .icon{

    font-size:55px;

}

.dashboard-card h3{

    margin-top:15px;

}

.dashboard-card h1{

    font-size:48px;

    margin-top:12px;

}

.blue{

    border-color:#3498db;

}

.blue h1{

    color:#3498db;

}

.green{

    border-color:#27ae60;

}

.green h1{

    color:#27ae60;

}

.orange{

    border-color:#f39c12;

}

.orange h1{

    color:#f39c12;

}

@media(max-width:1000px){

.actions-grid{

grid-template-columns:1fr 1fr;

}

}

@media(max-width:700px){

.actions-grid{

grid-template-columns:1fr;

}

.dashboard-card{

margin-bottom:20px;

}

}

</style>

</body>
</html>