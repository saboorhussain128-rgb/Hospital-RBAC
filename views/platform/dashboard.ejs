<!DOCTYPE html>
<html>

<%- include("../partials/header") %>

<body style="margin:0; font-family:Arial; background:#f4f6f9;">

<%- include("../partials/sidebar") %>

<div style="
    margin-left:240px;
    padding:35px;
">

    <h1 style="margin-bottom:10px;">
        Platform Dashboard
    </h1>

    <p style="color:#666;">
        Welcome to the Platform Administration Panel.
    </p>

    <div style="
        display:grid;
        grid-template-columns:repeat(2,1fr);
        gap:25px;
        margin-top:35px;
    ">

        <div style="
            background:white;
            padding:25px;
            border-radius:12px;
            box-shadow:0 4px 10px rgba(0,0,0,.08);
        ">
            <h2>Create Hospital</h2>

            <p>Add a new hospital to the system.</p>

            <a href="/platform/create-hospital"
               style="
               display:inline-block;
               margin-top:15px;
               padding:10px 18px;
               background:#3498db;
               color:white;
               text-decoration:none;
               border-radius:6px;">
                Open
            </a>
        </div>

        <div style="
            background:white;
            padding:25px;
            border-radius:12px;
            box-shadow:0 4px 10px rgba(0,0,0,.08);
        ">
            <h2>View Hospitals</h2>

            <p>Manage all hospitals.</p>

            <a href="/platform/view-hospital"
               style="
               display:inline-block;
               margin-top:15px;
               padding:10px 18px;
               background:#27ae60;
               color:white;
               text-decoration:none;
               border-radius:6px;">
                Open
            </a>
        </div>

        <div style="
            background:white;
            padding:25px;
            border-radius:12px;
            box-shadow:0 4px 10px rgba(0,0,0,.08);
        ">
            <h2>Create Hospital Admin</h2>

            <p>Create and assign hospital administrators.</p>

            <a href="/platform/create-hospital-admin"
               style="
               display:inline-block;
               margin-top:15px;
               padding:10px 18px;
               background:#9b59b6;
               color:white;
               text-decoration:none;
               border-radius:6px;">
                Open
            </a>
        </div>

        <div style="
            background:white;
            padding:25px;
            border-radius:12px;
            box-shadow:0 4px 10px rgba(0,0,0,.08);
        ">
            <h2>View Hospital Admins</h2>

            <p>Manage hospital administrator accounts.</p>

            <a href="/platform/view-hospital-admin"
               style="
               display:inline-block;
               margin-top:15px;
               padding:10px 18px;
               background:#f39c12;
               color:white;
               text-decoration:none;
               border-radius:6px;">
                Open
            </a>
        </div>

    </div>

</div>

</body>
</html>