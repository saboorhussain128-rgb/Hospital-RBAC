<!DOCTYPE html>
<html>

<%- include("../partials/header") %>

<body style="margin:0;background:#f4f6f9;">

<%- include("../partials/sidebar") %>

<div class="page">

    <!-- ================= HEADER ================= -->

    <div class="card" style="text-align:center;margin-bottom:35px;">

        <h1 style="
            font-size:38px;
            color:#2c3e50;
            margin-bottom:8px;
        ">
            Platform Admin Dashboard
        </h1>

        <p style="
            font-size:17px;
            color:#7f8c8d;
        ">
            Welcome, Platform Administrator
        </p>

    </div>

    <!-- ================= STATISTICS ================= -->

    <div style="
        display:grid;
        grid-template-columns:repeat(2,1fr);
        gap:25px;
        margin-bottom:35px;
    ">

        <div class="card"
             style="
                text-align:center;
                border-top:5px solid #3498db;
             ">

            <div style="font-size:55px;">
                🏥
            </div>

            <h3>Hospitals</h3>

            <h1 style="
                color:#3498db;
                font-size:48px;
            ">
                <%= hospitalCount || 0 %>
            </h1>

        </div>

        <div class="card"
             style="
                text-align:center;
                border-top:5px solid #27ae60;
             ">

            <div style="font-size:55px;">
                👨‍⚕️
            </div>

            <h3>Hospital Admins</h3>

            <h1 style="
                color:#27ae60;
                font-size:48px;
            ">
                <%= adminCount || 0 %>
            </h1>

        </div>

    </div>

    <!-- ================= QUICK ACTIONS ================= -->

    <div class="card">

        <h2 style="
            text-align:center;
            margin-bottom:30px;
            color:#2c3e50;
        ">
            Quick Actions
        </h2>

        <div style="
            display:grid;
            grid-template-columns:repeat(3,1fr);
            gap:25px;
        ">

            <!-- Create Hospital -->

            <a href="/platform/create-hospital"
               style="text-decoration:none;color:inherit;">

                <div class="action-card">

                    <div style="font-size:55px;">🏥</div>

                    <h3>Create Hospital</h3>

                    <p>Create a new hospital.</p>

                </div>

            </a>

            <!-- View Hospital -->

            <a href="/platform/view-hospital"
               style="text-decoration:none;color:inherit;">

                <div class="action-card">

                    <div style="font-size:55px;">📋</div>

                    <h3>View Hospitals</h3>

                    <p>Manage all hospitals.</p>

                </div>

            </a>

            <!-- Create Admin -->

            <a href="/platform/create-hospital-admin"
               style="text-decoration:none;color:inherit;">

                <div class="action-card">

                    <div style="font-size:55px;">👤</div>

                    <h3>Create Hospital Admin</h3>

                    <p>Create administrator accounts.</p>

                </div>

            </a>

            <!-- View Admin -->

            <a href="/platform/view-hospital-admin"
               style="text-decoration:none;color:inherit;">

                <div class="action-card">

                    <div style="font-size:55px;">🔐</div>

                    <h3>View Hospital Admins</h3>

                    <p>Edit or remove administrators.</p>

                </div>

            </a>

            <!-- Audit Logs -->

            <a href="/platform/audit-logs"
               style="text-decoration:none;color:inherit;">

                <div class="action-card">

                    <div style="font-size:55px;">📜</div>

                    <h3>Audit Logs</h3>

                    <p>View complete activity history.</p>

                </div>

            </a>

        </div>

    </div>

</div>

<style>

.action-card{

    border:1px solid #e6e6e6;

    border-radius:12px;

    padding:35px;

    text-align:center;

    transition:.3s;

    cursor:pointer;

}

.action-card:hover{

    box-shadow:0 8px 25px rgba(0,0,0,.15);

    transform:translateY(-5px);

}

.action-card h3{

    margin:18px 0;

}

.action-card p{

    color:#777;

}

</style>

</body>

</html>