<!DOCTYPE html>
<html>

<%- include("../partials/header") %>

<body style="margin:0;background:#f4f6f9;">

<%- include("../partials/sidebar") %>

<div class="page">

    <!-- ================= PAGE HEADER ================= -->

    <div class="page-header">

        <div class="page-title">

            <h1>Hospital List</h1>

            <p>
                Manage all hospitals registered in the Hospital RBAC System.
            </p>

        </div>

        <div>

            <a href="/platform/dashboard" class="btn btn-gray">
                ← Dashboard
            </a>

            <a href="/platform/create-hospital"
               class="btn btn-green"
               style="margin-left:10px;">
                + Create Hospital
            </a>

        </div>

    </div>

    <!-- ================= TABLE CARD ================= -->

    <div class="card">

        <table class="table">

            <thead>

                <tr>

                    <th>S.No</th>

                    <th>Hospital Name</th>

                    <th>Address</th>

                    <th>Status</th>

                    <th>Actions</th>

                </tr>

            </thead>

            <tbody>

            <% if(hospitals.length > 0){ %>

                <% hospitals.forEach((hospital,index)=>{ %>

                <tr>

                    <td><%= index+1 %></td>

                    <td>

                        <strong>
                            <%= hospital.name %>
                        </strong>

                    </td>

                    <td>

                        <%= hospital.address %>

                    </td>

                    <td>

                        <% if(hospital.status==="active"){ %>

                            <span class="status active">
                                Active
                            </span>

                        <% } else { %>

                            <span class="status inactive">
                                Inactive
                            </span>

                        <% } %>

                    </td>

                    <td>

                        <a href="/platform/edit-hospital/<%= hospital._id %>"
                           class="action-btn edit-btn">
                            Edit
                        </a>

                        <a href="/platform/delete-hospital/<%= hospital._id %>"
                           class="action-btn delete-btn"
                           onclick="return confirm('Delete this hospital?')">
                            Delete
                        </a>

                    </td>

                </tr>

                <% }) %>

            <% } else { %>

                <tr>

                    <td colspan="5" class="empty">

                        No hospitals found.

                    </td>

                </tr>

            <% } %>

            </tbody>

        </table>

        <div class="table-footer">

            Total Hospitals :
            <strong><%= hospitals.length %></strong>

        </div>

    </div>

</div>

</body>
</html>