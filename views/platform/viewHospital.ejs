<!DOCTYPE html>
<html>

<%- include("../partials/header") %>

<body style="margin:0;font-family:Arial;background:#f4f6f9;">

<%- include("../partials/sidebar") %>

<div style="margin-left:240px;padding:30px;">

    <!-- TOP BAR -->
    <div style="display:flex;justify-content:space-between;margin-bottom:20px;">

        <a href="/platform/dashboard"
           style="background:#34495e;color:white;padding:10px 16px;
                  text-decoration:none;border-radius:6px;">
            ← Back to Dashboard
        </a>

        <a href="/platform/create-hospital"
           style="background:#27ae60;color:white;padding:10px 16px;
                  text-decoration:none;border-radius:6px;">
            + Create Hospital
        </a>

    </div>

    <div style="background:white;padding:25px;border-radius:10px;">

        <h2>Hospital List</h2>

        <table style="width:100%;border-collapse:collapse;margin-top:20px;">

            <thead>

                <tr style="background:#ecf0f1;">

                    <th style="padding:12px;">S.No</th>
                    <th>Name</th>
                    <th>Address</th>
                    <th>Status</th>

                </tr>

            </thead>

            <tbody>

            <% if (hospitals.length > 0) { %>

                <% hospitals.forEach((hospital,index)=>{ %>

                    <tr style="border-bottom:1px solid #ddd;">

                        <td style="padding:12px;">
                            <%= index + 1 %>
                        </td>

                        <td>
                            <%= hospital.name %>
                        </td>

                        <td>
                            <%= hospital.address %>
                        </td>

                        <td>

                            <% if(hospital.status==="active"){ %>

                                <span style="color:green;font-weight:bold;">
                                    Active
                                </span>

                            <% } else { %>

                                <span style="color:red;font-weight:bold;">
                                    Inactive
                                </span>

                            <% } %>

                        </td>

                    </tr>

                <% }) %>

            <% } else { %>

                <tr>

                    <td colspan="4"
                        style="padding:20px;text-align:center;">

                        No hospitals found.

                    </td>

                </tr>

            <% } %>

            </tbody>

        </table>

    </div>

</div>

</body>
</html>