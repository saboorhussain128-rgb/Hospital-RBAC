<!DOCTYPE html>
<html>

<%- include("../partials/header") %>

<body style="margin:0; font-family:Arial; background:#f4f6f9;">

<%- include("../partials/sidebar") %>

<div style="margin-left:240px; padding:30px;">

    <!-- TOP BAR -->
    <div style="display:flex; justify-content:space-between; margin-bottom:20px;">

        <a href="/platform/dashboard" style="
            background:#34495e;
            color:white;
            padding:8px 14px;
            border-radius:6px;
            text-decoration:none;">
            ← Back to Dashboard
        </a>

        <a href="/platform/create-hospital-admin" style="
            background:#9b59b6;
            color:white;
            padding:8px 14px;
            border-radius:6px;
            text-decoration:none;">
            + Create Hospital Admin
        </a>

    </div>

    <div style="background:white; padding:20px; border-radius:10px;">

        <h2 style="margin-bottom:15px;">Hospital Admin List</h2>

        <table style="width:100%; border-collapse:collapse;">

            <tr style="background:#f2f2f2;">
                <th style="padding:10px;">S.No</th>
                <th>Name</th>
                <th>Email</th>
                <th>Hospital</th>
                <th>Actions</th>
            </tr>

            <% if (admins && admins.length > 0) { %>

                <% admins.forEach((a, index) => { %>

                    <tr style="border-bottom:1px solid #ddd;">

                        <td style="padding:10px;"><%= index + 1 %></td>
                        <td><%= a.name %></td>
                        <td><%= a.email %></td>
                        <td><%= a.hospital?.name %></td>

                        <td>
                            <a href="/platform/delete-hospital-admin/<%= a._id %>"
                               onclick="return confirm('Delete this admin?')"
                               style="color:red;">
                                Delete
                            </a>
                        </td>

                    </tr>

                <% }) %>

            <% } else { %>

                <tr>
                    <td colspan="5" style="text-align:center;padding:20px;">
                        No hospital admins found
                    </td>
                </tr>

            <% } %>

        </table>

    </div>

</div>

</body>
</html>