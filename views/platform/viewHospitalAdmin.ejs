<!DOCTYPE html>
<html>

<%- include("../partials/header") %>

<body style="margin:0;background:#f4f6f9;">

<%- include("../partials/sidebar") %>

<div class="page">

    <!-- ================= PAGE HEADER ================= -->

    <div class="page-header">

        <div class="page-title">

            <h1>Hospital Admin List</h1>

            <p>
                Manage Hospital Administrators and their RBAC permissions.
            </p>

        </div>

        <div>

            <a href="/platform/dashboard"
               class="btn btn-gray">

                ← Dashboard

            </a>

            <a href="/platform/create-hospital-admin"
               class="btn btn-blue"
               style="margin-left:10px;">

                + Create Hospital Admin

            </a>

        </div>

    </div>

    <!-- ================= TABLE ================= -->

    <div class="card">

        <table class="table">

            <thead>

                <tr>

                    <th>S.No</th>
                    <th>Hospital</th>
                    <th>Administrator</th>
                    <th>Email</th>
                    <th>Permissions</th>
                    <th>Actions</th>

                </tr>

            </thead>

            <tbody>

                <% if(admins.length > 0){ %>

                    <% admins.forEach((admin,index)=>{ %>

                        <tr>

                            <td>

                                <%= index+1 %>

                            </td>

                            <td>

                                <strong>

                                    <%= admin.hospital ? admin.hospital.name : "-" %>

                                </strong>

                            </td>

                            <td>

                                <%= admin.name %>

                            </td>

                            <td>

                                <%= admin.email %>

                            </td>

                            <td>

                                <span class="status active">

                                    <%= admin.permissions.length %> Permissions

                                </span>

                            </td>

                            <td>

                                <a
                                    href="/platform/edit-hospital-admin/<%= admin._id %>"
                                    class="action-btn edit-btn">

                                    Edit

                                </a>

                                <a
                                    href="/platform/delete-hospital-admin/<%= admin._id %>"
                                    class="action-btn delete-btn"
                                    onclick="return confirm('Delete this Hospital Admin?')">

                                    Delete

                                </a>

                            </td>

                        </tr>

                    <% }) %>

                <% } else { %>

                    <tr>

                        <td colspan="6" class="empty">

                            No Hospital Admins Found

                        </td>

                    </tr>

                <% } %>

            </tbody>

        </table>

        <div class="table-footer">

            Total Hospital Admins :
            <strong>

                <%= admins.length %>

            </strong>

        </div>

    </div>

</div>

</body>
</html>