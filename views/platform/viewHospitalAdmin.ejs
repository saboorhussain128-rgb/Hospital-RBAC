<!DOCTYPE html>
<html>

<%- include("../partials/header") %>

<body style="margin:0;font-family:Arial;background:#f4f6f9;">

<%- include("../partials/sidebar") %>

<div style="margin-left:240px;padding:30px;">

    <!-- TOP BAR -->
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">

        <a href="/platform/dashboard"
           style="background:#34495e;
                  color:white;
                  padding:10px 18px;
                  border-radius:6px;
                  text-decoration:none;">
            ← Back to Dashboard
        </a>

        <a href="/platform/create-hospital-admin"
           style="background:#9b59b6;
                  color:white;
                  padding:10px 18px;
                  border-radius:6px;
                  text-decoration:none;">
            + Create Hospital Admin
        </a>

    </div>

    <div style="background:white;padding:25px;border-radius:10px;">

        <h2>Hospital Admin List</h2>

        <table style="width:100%;border-collapse:collapse;margin-top:20px;">

            <thead>

                <tr style="background:#ecf0f1;">

                    <th style="padding:12px;">S.No</th>
                    <th>Hospital</th>
                    <th>Admin Name</th>
                    <th>Email</th>
                    <th>Permissions</th>
                    <th>Action</th>

                </tr>

            </thead>

            <tbody>

            <% if (admins.length > 0) { %>

                <% admins.forEach((admin,index)=>{ %>

                    <tr style="border-bottom:1px solid #ddd;">

                        <td style="padding:12px;">
                            <%= index + 1 %>
                        </td>

                        <td>
                            <%= admin.hospital ? admin.hospital.name : "-" %>
                        </td>

                        <td>
                            <%= admin.name %>
                        </td>

                        <td>
                            <%= admin.email %>
                        </td>

                        <td>

                            <% if(admin.permissions.length){ %>

                                <%= admin.permissions.join(", ") %>

                            <% } else { %>

                                No Permissions

                            <% } %>

                        </td>

                        <td>

                            <a href="/platform/delete-hospital-admin/<%= admin._id %>"
                               onclick="return confirm('Delete this Hospital Admin?')"
                               style="color:red;text-decoration:none;">

                                Delete

                            </a>

                        </td>

                    </tr>

                <% }) %>

            <% } else { %>

                <tr>

                    <td colspan="6"
                        style="text-align:center;padding:20px;">

                        No Hospital Admins Found

                    </td>

                </tr>

            <% } %>

            </tbody>

        </table>

    </div>

</div>

</body>
</html>