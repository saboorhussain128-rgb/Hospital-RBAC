<!DOCTYPE html>
<html>

<%- include("../partials/header") %>

<body style="margin:0;font-family:Arial;background:#eef1f7;">

<div style="display:flex;min-height:100vh;">

    <!-- Sidebar -->

    <div style="width:240px;background:#1f2d3d;color:white;">

        <div style="padding:30px;font-size:34px;font-weight:bold;border-bottom:1px solid rgba(255,255,255,.15);">
            Hospital Admin
        </div>

        <div style="padding:20px;">

            <a href="/hospital/dashboard"
               style="display:block;background:#34495e;color:white;text-decoration:none;padding:15px;border-radius:8px;margin-bottom:15px;text-align:center;">
                Dashboard
            </a>

            <a href="/hospital/logout"
               style="display:block;background:#e74c3c;color:white;text-decoration:none;padding:15px;border-radius:8px;text-align:center;">
                Logout
            </a>

        </div>

    </div>

    <!-- Content -->

    <div style="flex:1;padding:40px;">

        <div style="display:flex;justify-content:space-between;margin-bottom:25px;">

            <a href="/hospital/view-doctor"
               style="background:#34495e;color:white;padding:12px 18px;border-radius:8px;text-decoration:none;">
                ← View Doctors
            </a>

        </div>

        <div style="background:white;padding:30px;border-radius:12px;box-shadow:0 3px 10px rgba(0,0,0,.12);">

            <h2>Edit Doctor</h2>

            <form action="/hospital/edit-doctor/<%= doctor._id %>" method="POST">

                <label><b>Doctor Name</b></label>

                <input
                    type="text"
                    name="name"
                    value="<%= doctor.name %>"
                    required
                    style="width:100%;padding:12px;margin:10px 0 20px 0;"
                >

                <label><b>Email</b></label>

                <input
                    type="email"
                    name="email"
                    value="<%= doctor.email %>"
                    required
                    style="width:100%;padding:12px;margin:10px 0 25px 0;"
                >

                <button
                    style="background:#3498db;color:white;border:none;padding:14px 25px;border-radius:8px;cursor:pointer;">
                    Update Doctor
                </button>

            </form>

        </div>

    </div>

</div>

</body>
</html>