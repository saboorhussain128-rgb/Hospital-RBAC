<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">

    <title>Set New Password</title>

    <style>

        *{

            margin:0;
            padding:0;
            box-sizing:border-box;

        }

        body{

            background:#f4f6f9;
            font-family:Arial,Helvetica,sans-serif;

            display:flex;
            justify-content:center;
            align-items:center;

            height:100vh;

        }

        .card{

            width:430px;

            background:white;

            padding:35px;

            border-radius:10px;

            box-shadow:0 5px 15px rgba(0,0,0,.15);

        }

        h2{

            text-align:center;

            margin-bottom:10px;

        }

        p{

            text-align:center;

            color:#666;

            margin-bottom:25px;

        }

        label{

            display:block;

            margin-top:15px;

            font-weight:bold;

        }

        input{

            width:100%;

            padding:12px;

            margin-top:8px;

            border:1px solid #ccc;

            border-radius:5px;

        }

        button{

            width:100%;

            padding:12px;

            margin-top:25px;

            border:none;

            background:#0d6efd;

            color:white;

            font-size:16px;

            border-radius:5px;

            cursor:pointer;

        }

        button:hover{

            background:#0b5ed7;

        }

    </style>

</head>

<body>

<div class="card">

<h2>

Welcome

</h2>

<p>

Please create your new password before continuing.

</p>

<form action="/hospital/change-password" method="POST">

<label>

New Password

</label>

<input

type="password"

name="newPassword"

required

>

<label>

Confirm Password

</label>

<input

type="password"

name="confirmPassword"

required

>

<button>

Save Password

</button>

</form>

</div>

</body>

</html>