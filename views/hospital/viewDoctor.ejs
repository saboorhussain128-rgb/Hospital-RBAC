<!DOCTYPE html>
<html>

<%- include("../partials/header") %>

<body style="margin:0;background:#f4f6f9;">

<div style="display:flex;min-height:100vh;">

    <!-- ================= SIDEBAR ================= -->

    <div style="
        width:220px;
        background:#1f2a38;
        color:white;
        padding:20px;
        box-shadow:2px 0 10px rgba(0,0,0,.15);
    ">

        <h2 style="text-align:center;margin-bottom:25px;">
            Hospital Admin
        </h2>

        <hr style="border:.5px solid rgba(255,255,255,.2);">

        <div style="
            margin-top:25px;
            display:flex;
            flex-direction:column;
            gap:15px;
        ">

            <a href="/hospital/dashboard"
               style="
                    background:#5dade2;
                    color:#1f2a38;
                    text-decoration:none;
                    padding:12px;
                    border-radius:8px;
                    text-align:center;
                    font-weight:bold;
               ">
                Dashboard
            </a>

            <a href="/hospital/logout"
               style="
                    background:#e74c3c;
                    color:white;
                    text-decoration:none;
                    padding:12px;
                    border-radius:8px;
                    text-align:center;
                    font-weight:bold;
               ">
                Logout
            </a>

        </div>

    </div>

    <!-- ================= CONTENT ================= -->

    <div class="page">

        <!-- Header -->

        <div class="page-header">

            <div class="page-title">

                <h1>Doctor List</h1>

                <p>
                    View, update and delete doctors.
                </p>

            </div>

            <div>

                <a href="/hospital/dashboard" class="btn btn-gray">
                    ← Dashboard
                </a>

                <a href="/hospital/create-doctor" class="btn btn-green">
                    + Create Doctor
                </a>

            </div>

        </div>

        <!-- Table -->

        <div class="card">

            <table class="table">

                <thead>

                <tr>

                    <th>S.No</th>
                    <th>Doctor Name</th>
                    <th>Email</th>
                    <th>Actions</th>

                </tr>

                </thead>

                <tbody>

                <% if(doctors.length){ %>

                    <% doctors.forEach((doctor,index)=>{ %>

                    <tr>

                        <td><%= index+1 %></td>

                        <td>
                            <strong><%= doctor.name %></strong>
                        </td>

                        <td>
                            <%= doctor.email %>
                        </td>

                        <td>

                            <a
                                href="/hospital/edit-doctor/<%= doctor._id %>"
                                class="action-btn edit-btn"
                            >
                                Edit
                            </a>

                            <a
                                href="/hospital/delete-doctor/<%= doctor._id %>"
                                class="action-btn delete-btn"
                                onclick="return confirm('Delete this doctor?')"
                            >
                                Delete
                            </a>

                        </td>

                    </tr>

                    <% }) %>

                <% } else { %>

                    <tr>

                        <td colspan="4" class="empty">

                            No Doctors Found

                        </td>

                    </tr>

                <% } %>

                </tbody>

            </table>

            <div class="table-footer">

                Total Doctors :
                <strong><%= doctors.length %></strong>

            </div>

        </div>

    </div>

</div>

</body>
</html>