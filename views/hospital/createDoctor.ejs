<!DOCTYPE html>
<html>

<%- include("../partials/header") %>

<body style="margin:0;background:#f4f6f9;">

<div style="display:flex;min-height:100vh;">

    <!-- ================= SIDEBAR ================= -->

    <div style="
        width:220px;
        background:#1f2a38;
        color:white;
        padding:20px;
        box-shadow:2px 0 10px rgba(0,0,0,.15);
    ">

        <h2 style="text-align:center;margin-bottom:25px;">
            Hospital Admin
        </h2>

        <hr style="border:.5px solid rgba(255,255,255,.2);">

        <div style="
            margin-top:25px;
            display:flex;
            flex-direction:column;
            gap:15px;
        ">

            <a href="/hospital/dashboard"
               style="
                    background:#5dade2;
                    color:#1f2a38;
                    text-decoration:none;
                    padding:12px;
                    border-radius:8px;
                    text-align:center;
                    font-weight:bold;
               ">
                Dashboard
            </a>

            <a href="/hospital/logout"
               style="
                    background:#e74c3c;
                    color:white;
                    text-decoration:none;
                    padding:12px;
                    border-radius:8px;
                    text-align:center;
                    font-weight:bold;
               ">
                Logout
            </a>

        </div>

    </div>

    <!-- ================= CONTENT ================= -->

    <div style="flex:1;padding:35px;">

        <!-- Header -->

        <div class="card">

            <div style="
                display:flex;
                justify-content:space-between;
                align-items:center;
                margin-bottom:25px;
            ">

                <div>

                    <h1 style="margin:0;">
                        Create Doctor
                    </h1>

                    <p style="margin-top:8px;color:#777;">
                        Register a new doctor for your hospital.
                    </p>

                </div>

                <div>

                    <a href="/hospital/dashboard"
                       class="btn btn-gray">
                        ← Dashboard
                    </a>

                    <a href="/hospital/view-doctor"
                       class="btn btn-green">
                        View Doctors
                    </a>

                </div>

            </div>

            <hr style="margin-bottom:25px;">

            <form action="/hospital/create-doctor" method="POST">

                <div style="margin-bottom:20px;">

                    <label style="font-weight:bold;">
                        Doctor Name
                    </label>

                    <input
                        type="text"
                        name="name"
                        required
                        placeholder="Enter Doctor Name"
                        style="
                            width:100%;
                            padding:14px;
                            margin-top:8px;
                            border:1px solid #dcdcdc;
                            border-radius:8px;
                            font-size:15px;
                        "
                    >

                </div>

                <div style="margin-bottom:30px;">

                    <label style="font-weight:bold;">
                        Email Address
                    </label>

                    <input
                        type="email"
                        name="email"
                        required
                        placeholder="Enter Email Address"
                        style="
                            width:100%;
                            padding:14px;
                            margin-top:8px;
                            border:1px solid #dcdcdc;
                            border-radius:8px;
                            font-size:15px;
                        "
                    >

                </div>

                <button
                    type="submit"
                    class="btn btn-blue"
                    style="border:none;cursor:pointer;"
                >
                    Create Doctor
                </button>

            </form>

        </div>

    </div>

</div>

</body>
</html>