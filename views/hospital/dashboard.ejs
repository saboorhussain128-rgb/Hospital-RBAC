<!DOCTYPE html>
<html>

<%- include("../partials/header") %>

<body style="margin:0; font-family:Arial; background:#f4f6f9;">

<%- include("../partials/hospitalSidebar") %>

<div style="margin-left:240px; padding:35px;">

    <h1 style="margin-bottom:10px;">Hospital Dashboard</h1>

    <p style="color:#666;">
        Welcome,
        <strong><%= admin ? admin.name : "Hospital Admin" %></strong>
    </p>

    <div style="
        display:grid;
        grid-template-columns:repeat(2,1fr);
        gap:25px;
        margin-top:35px;
    ">

        <div style="
            background:white;
            padding:25px;
            border-radius:12px;
            box-shadow:0 4px 10px rgba(0,0,0,.08);
        ">
            <h2>Create Doctor</h2>

            <p>Add a new doctor to your hospital.</p>

            <a href="/hospital/create-doctor"
               style="
               display:inline-block;
               margin-top:15px;
               text-decoration:none;
               background:#3498db;
               color:white;
               padding:10px 18px;
               border-radius:6px;">
               Open
            </a>

        </div>

        <div style="
            background:white;
            padding:25px;
            border-radius:12px;
            box-shadow:0 4px 10px rgba(0,0,0,.08);
        ">
            <h2>View Doctors</h2>

            <p>View all doctors in your hospital.</p>

            <a href="/hospital/view-doctor"
               style="
               display:inline-block;
               margin-top:15px;
               text-decoration:none;
               background:#27ae60;
               color:white;
               padding:10px 18px;
               border-radius:6px;">
               Open
            </a>

        </div>

        <div style="
            background:white;
            padding:25px;
            border-radius:12px;
            box-shadow:0 4px 10px rgba(0,0,0,.08);
        ">
            <h2>Delete Doctor</h2>

            <p>Remove doctors from your hospital.</p>

            <a href="/hospital/view-doctor"
               style="
               display:inline-block;
               margin-top:15px;
               text-decoration:none;
               background:#e74c3c;
               color:white;
               padding:10px 18px;
               border-radius:6px;">
               Open
            </a>

        </div>

    </div>

</div>

</body>
</html>