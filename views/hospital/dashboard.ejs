<!DOCTYPE html>
<html>

<%- include("../partials/header") %>

<body style="margin:0;font-family:Arial;background:#eef1f7;">

<div style="display:flex;min-height:100vh;">

    <!-- ================= SIDEBAR ================= -->

    <div style="
        width:240px;
        background:#1f2d3d;
        color:white;
        display:flex;
        flex-direction:column;
    ">

        <div style="
            padding:30px;
            font-size:34px;
            font-weight:bold;
            border-bottom:1px solid rgba(255,255,255,.15);
        ">
            Hospital Admin
        </div>

        <div style="padding:20px;">

            <div style="
                background:#34495e;
                padding:15px;
                border-radius:8px;
                margin-bottom:15px;
                font-size:18px;
            ">
                Dashboard
            </div>

            <a href="/hospital/logout"
               style="
                display:block;
                text-align:center;
                background:#e74c3c;
                color:white;
                text-decoration:none;
                padding:14px;
                border-radius:8px;
                font-size:18px;
               ">
                Logout
            </a>

        </div>

    </div>

    <!-- ================= CONTENT ================= -->

    <div style="flex:1;padding:40px;">

        <h1 style="margin-top:0;">
            Hospital Admin Dashboard
        </h1>

        <hr>

        <div style="
            display:grid;
            grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
            gap:25px;
            margin-top:40px;
        ">

            <!-- CREATE DOCTOR -->

            <a href="/hospital/create-doctor"
               style="
                text-decoration:none;
                color:white;
               ">

                <div style="
                    background:#3498db;
                    padding:40px;
                    border-radius:12px;
                    text-align:center;
                    font-size:24px;
                    font-weight:bold;
                    box-shadow:0 3px 10px rgba(0,0,0,.15);
                ">

                    <br><br>

                    Create Doctor

                </div>

            </a>

            <!-- VIEW DOCTOR -->

            <a href="/hospital/view-doctor"
               style="
                text-decoration:none;
                color:white;
               ">

                <div style="
                    background:#27ae60;
                    padding:40px;
                    border-radius:12px;
                    text-align:center;
                    font-size:24px;
                    font-weight:bold;
                    box-shadow:0 3px 10px rgba(0,0,0,.15);
                ">

                    <br><br>

                    View Doctors

                </div>

            </a>

            <!-- DELETE DOCTOR -->

            <a href="/hospital/view-doctor"
               style="
                text-decoration:none;
                color:white;
               ">

                <div style="
                    background:#e74c3c;
                    padding:40px;
                    border-radius:12px;
                    text-align:center;
                    font-size:24px;
                    font-weight:bold;
                    box-shadow:0 3px 10px rgba(0,0,0,.15);
                ">

                    <br><br>

                    Delete Doctor

                </div>

            </a>

        </div>

    </div>

</div>

</body>
</html>