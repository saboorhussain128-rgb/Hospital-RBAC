<!DOCTYPE html>
<html>

<%- include("../partials/header") %>

<body style="margin:0;background:#f4f6f9;">

<div style="display:flex;min-height:100vh;">

    <!-- ================= SIDEBAR ================= -->

    <div style="
        width:220px;
        background:#1f2a38;
        color:white;
        padding:20px;
        box-shadow:2px 0 10px rgba(0,0,0,.15);
    ">

        <h2 style="
            text-align:center;
            margin-bottom:25px;
        ">
            Hospital Admin
        </h2>

        <hr style="border:.5px solid rgba(255,255,255,.2);">

        <div style="
            margin-top:25px;
            display:flex;
            flex-direction:column;
            gap:15px;
        ">

            <div style="
                background:#5dade2;
                color:#1f2a38;
                padding:12px;
                border-radius:8px;
                text-align:center;
                font-weight:bold;
                font-size:17px;
            ">
                Dashboard
            </div>

            <a href="/hospital/logout"
               style="
                background:#e74c3c;
                color:white;
                text-decoration:none;
                padding:12px;
                border-radius:8px;
                text-align:center;
                font-weight:bold;
            ">
                Logout
            </a>

        </div>

    </div>

    <!-- ================= CONTENT ================= -->

    <div style="flex:1;padding:35px;">

        <!-- Header -->

        <div class="card" style="text-align:center;margin-bottom:30px;">

            <h1 style="margin-bottom:10px;">
                Hospital Admin
            </h1>

            <p style="color:#666;">
                Welcome to the Hospital Management Dashboard
            </p>

        </div>

        <!-- Statistics -->

        <div style="
            display:grid;
            grid-template-columns:repeat(2,1fr);
            gap:25px;
            margin-bottom:35px;
        ">

            <div class="card" style="text-align:center;">

                <div style="font-size:42px;">🩺</div>

                <h3 style="margin:15px 0;">
                    Doctors
                </h3>

                <h1 style="color:#3498db;">
                    <%= doctorCount || 0 %>
                </h1>

            </div>

            <div class="card" style="text-align:center;">

                <div style="font-size:42px;">🏥</div>

                <h3 style="margin:15px 0;">
                    Hospital
                </h3>

                <h2 style="color:#27ae60;">
                    <%= hospitalName || "Hospital" %>
                </h2>

            </div>

        </div>

        <!-- Quick Actions -->

        <div class="card">

            <h2 style="
                text-align:center;
                margin-bottom:25px;
            ">
                Quick Actions
            </h2>

            <div style="
                display:grid;
                grid-template-columns:repeat(2,1fr);
                gap:25px;
            ">

                <a href="/hospital/create-doctor"
                   style="text-decoration:none;color:inherit;">

                    <div style="
                        border:1px solid #ecf0f1;
                        border-radius:12px;
                        padding:30px;
                        text-align:center;
                    ">

                        <div style="font-size:42px;">➕</div>

                        <h3>Create Doctor</h3>

                    </div>

                </a>

                <a href="/hospital/view-doctor"
                   style="text-decoration:none;color:inherit;">

                    <div style="
                        border:1px solid #ecf0f1;
                        border-radius:12px;
                        padding:30px;
                        text-align:center;
                    ">

                        <div style="font-size:42px;">📋</div>

                        <h3>View Doctors</h3>

                    </div>

                </a>

                <a href="/hospital/view-doctor"
                   style="
                    grid-column:1 / span 2;
                    text-decoration:none;
                    color:inherit;
                ">

                    <div style="
                        border:1px solid #ecf0f1;
                        border-radius:12px;
                        padding:30px;
                        text-align:center;
                    ">

                        <div style="font-size:42px;">🗑️</div>

                        <h3>Delete Doctor</h3>

                        <p style="color:#777;">
                            Select a doctor from the list to delete.
                        </p>

                    </div>

                </a>

            </div>

        </div>

    </div>

</div>

</body>
</html>